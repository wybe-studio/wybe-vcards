{
	"name": "acme",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"clean": "git clean -xdf .cache .next build dist node_modules",
		"build": "next build",
		"deploy": "npm run build",
		"dev": "next dev",
		"e2e": "npx playwright test --ui",
		"e2e:ci": "npx playwright install && npx playwright test",
		"format": "biome format",
		"format:write": "biome format --write",
		"lint": "biome lint",
		"lint:write": "biome lint --write",
		"check": "biome check",
		"check:write": "biome check --write --unsafe",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"test": "npm run test:unit",
		"test:unit": "npm run with-dev-env -- vitest",
		"test:db": "RUN_DB_TESTS=true npm run with-dev-env -- vitest",
		"test:watch": "npm run test:unit -- --watch",
		"test:coverage": "npm run with-dev-env -- vitest run --coverage",
		"test:e2e": "npm run with-dev-env -- playwright test",
		"test:e2e:ui": "npm run with-dev-env -- playwright test --ui",
		"test:e2e:debug": "npm run with-dev-env -- playwright test --debug",
		"test:e2e:headed": "npm run with-dev-env -- playwright test --headed",
		"test:e2e:setup": "npm run with-dev-env -- playwright install",
		"with-dev-env": "dotenv -e ./.env --",
		"db:start": "npx supabase start",
		"db:stop": "npx supabase stop",
		"db:reset": "npx supabase db reset",
		"db:studio": "npx supabase studio",
		"db:typegen": "npx supabase gen types typescript --local > lib/supabase/database.types.ts",
		"db:migrate": "npx supabase migration new",
		"db:link:staging": "npx supabase link --project-ref bwgfqckcsxrgcdfdveuv",
		"db:link:prod": "npx supabase link --project-ref bidqxqljyvtnemhjxpbb",
		"db:push": "npx supabase db push",
		"db:typegen:remote": "npx supabase gen types typescript --linked > lib/supabase/database.types.ts",
		"stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
		"stripe:trigger": "stripe trigger",
		"email:dev": "npx react-email dev --dir lib/email/templates --port 3001",
		"prepare": "husky",
		"postinstall": "fumadocs-mdx",
		"deps:check": "npx npm-check-updates",
		"deps:update": "npx npm-check-updates -u"
	},
